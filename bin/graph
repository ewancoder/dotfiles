#!/usr/bin/python
import matplotlib.pyplot as plt
import numpy as np
import datetime
import os

os.system('scp root@192.168.100.11:/root/graph.log /tmp')
humid, temp, fahr, light, dates = np.loadtxt('/tmp/graph.log', skiprows=1, unpack=True)
xdates = [datetime.datetime.strptime(str(int(date)),'%m%d%Y%H%M%S') for date in dates]

fig = plt.figure()

temps = plt.subplot(211)
plt.plot(xdates, temp, '-', label='Celcius Temperature, C')
plt.plot(xdates, humid, '-', label='Humidity, %')
plt.ylabel('Weather')
plt.grid()
leg = plt.legend(loc='best', fancybox=True)
leg.get_frame().set_alpha(0.5)

lights = plt.subplot(212, sharex=temps)
plt.plot(xdates, light, '-', label='Light')
plt.ylabel('Light')
plt.grid()

fig.autofmt_xdate()
plt.show()
