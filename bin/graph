#!/usr/bin/python
import matplotlib.pyplot as plt
import numpy as np
import datetime
import os
import sys

#Get data
os.system('scp root@192.168.100.11:/root/graph.log /tmp/raw.log')

#Prepare (shrink) data
def prepare():
    data = open('/tmp/raw.log', 'r')
    f = open('/tmp/graph.log', 'w')
    l1, l2, l3, newline, oldline = '', '', '', '', ''

    def main(line):
        if not (l2[0:4] == l1[0:4] and l2[0:4] == l3[0:4]):
            f.write(str(line) + '')

    for line in data:
        l = line.split()
        if newline == '':
            newline = line
        else:
            oldline = newline
            newline = line

        if l1 == '':
            l1 = l
            f.write(line)
        elif l2 == '':
            l2 = l
        elif l3 == '':
            l3 = l
            main(oldline)
        else:
            l1 = l2
            l2 = l3
            l3 = l
            main(oldline)

    f.close()

#Process data
humid, temp, fahr, light, dates = np.loadtxt('/tmp/graph.log', skiprows=1, unpack=True)
xdates = [datetime.datetime.strptime(str(int(date)),'%m%d%Y%H%M%S') for date in dates]

fig = plt.figure()
fig.suptitle('Weather & Light sensors visualisation')

temps = plt.subplot(211)
if '-c' in sys.argv:
    plt.plot(xdates, temp, '-', label='Celcius Temperature, C')
else:
    plt.plot(xdates, fahr, '-', label='Temperature, F')
plt.plot(xdates, humid, '-', label='Humidity, %')
plt.ylabel('Weather')
plt.grid()
leg = plt.legend(loc='best', fancybox=True)
leg.get_frame().set_alpha(0.5)

lights = plt.subplot(212, sharex=temps)
plt.plot(xdates, light, '-', label='Light')
plt.ylabel('Light')
plt.grid()
plt.ylim((0,1050))

fig.autofmt_xdate()
plt.show()
