#!/bin/bash
echo "Start?"
read

pact install tmux && pact update git
read

git clone http://github.com/ewancoder/dotfiles.git ~/.dotfiles
ln -fs ~/.dotfiles/.minttyrc ~/
ln -fs ~/.dotfiles/.zshrc ~/
ln -fs ~/.dotfiles/.zsh_aliases ~/
ln -fs ~/.dotfiles/.tmux.conf ~/
ln -fs ~/.dotfiles/.oh-my-zsh/themes/ewancoder.zsh-theme ~/.oh-my-zsh/themes

rm -rf ~/.vim /etc/vimrc
ln -fs ~/.dotfiles/.vim ~/

mkdir ~/.vim/{swap,backup}
folder=~/.vim/spell
mkdir -p $folder
(
    cd $folder
    ls ../../..
    ls ../..
    ls ..
    ls
    read
    curl -LO https://www.dropbox.com/sh/opimtkj7948ket2/AABUDDjVTeWC6hvLxkZuR3E8a/my.utf-8.add
    curl -LO https://www.dropbox.com/sh/opimtkj7948ket2/AAAln0hJGsdg40S-G_BrDkNAa/my.utf-8.add.spl
    curl -LO https://www.dropbox.com/sh/opimtkj7948ket2/AAA8_kUvUhzVgWDCwiYzfcATa/ru.utf-8.spl
    curl -LO https://www.dropbox.com/sh/opimtkj7948ket2/AAA5s0O8dEzNt88xwjOz1zZea/ru.utf-8.sug
)

cd ~/.dotfiles
git submodule update --init --recursive
vim +PluginInstall +qall

ln -s /d/Dropbox ~/Dropbox
ln -s /c/Users/i.zyrianov/Downloads ~/Downloads
