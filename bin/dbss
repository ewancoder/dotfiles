#!/bin/sh
# DropBox Screenshot Script (DBSS)
# Ewancoder, 2014
user_id=70091792
delay=0
quality=75
month=$(date +%B)
ssdir=Screenshots
dbdir=~/Dropbox/Public/$ssdir/$month
filename=$(date +%d-%H%M%S).png

mkdir -p $dbdir
cd $dbdir
scrot -d $delay -q $quality $filename
gst123 /usr/share/sounds/freedesktop/stereo/screen-capture.oga
 
url="http://dl.dropbox.com/u/$user_id/$ssdir/$month/$filename"
echo $url | xclip -sel clip
notify-send -t 3000 "Screenshot added" "Link in clip: http://dl.dropbox.com/u/70091792/Screenshots/$month/$filename ($month)"
