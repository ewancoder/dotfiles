#!/bin/bash
for repo in\
    /etc/.dotfiles\
    ~/.dotfiles\
    ~/archlive/releng\
    ~/btp\
    ~/eal\
    ~/rpidots\
    ~/site; do
    if [ -d $repo ]; then
        cd $repo
        git status | awk -v repo="`basename $repo`-`basename $(dirname $repo)`"\
            '/not staged|untracked/ {print "Unstaged: "repo};
            /ahead/ {print "Ahead: "repo};
            /to be committed/ {print "Staged: "repo}'
    fi
done
