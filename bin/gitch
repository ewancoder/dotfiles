#!/bin/bash
for repo in ~/.dotfiles ~/eal ~/btp /etc/.dotfiles ~/archlive/releng ~/rpidots ~/site; do
    if [ -d $repo ]; then
        cd $repo
        if [ ! "$(git status | grep -i "not staged\|untracked")" == "" -a "$1" == "" ]; then
            echo $repo-`basename $(dirname $repo)`
        fi
        if [ ! "$(git status | grep -i "ahead")" == "" -a "$1" == "blue" ]; then
            echo $repo-`basename $(dirname $repo)`
        fi
        if [ ! "$(git status | grep -i "to be committed")" == "" -a "$1" == "green" ]; then
            echo $repo-`basename $(dirname $repo)`
        fi
    fi
done
