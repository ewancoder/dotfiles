#!/bin/bash
for repo in ~/.dotfiles ~/eal ~/btp /etc/.dotfiles ~/archlive/releng ~/rpidots ~/site; do
    if [ -d $repo ]; then
        cd $repo
        if ! [ "$(git status | grep -i "changes\|untracked")" == "" ]; then
            if [ "$1" == "" ]; then
                echo $repo-`basename $(dirname $repo)`
            fi
        else
            if [ ! "$(git status | grep -i "ahead")" == "" -a ! "$1" == "" ]; then
                echo $repo-`basename $(dirname $repo)`
            fi
        fi
    fi
done
