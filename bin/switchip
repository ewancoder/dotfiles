#!/bin/bash
echo -e `sed -n 2p .ip_rpi`\\n`head -1 ~/.ip_rpi` > ~/.ip_rpi
if [ "`head -1 ~/.ip_rpi`" == "192.168.100.11" ]; then
    sudo netctl disable jgurda
    sudo netctl enable wireless-wpa-static
    echo "Loaded HOME profile (wireles-wpa-static)"
else
    sudo netctl disable wireless-wpa-static
    sudo netctl enable jgurda
    echo "Loaded OUTDOORS profile (jgurda)"
fi
echo "Please, reboot"
