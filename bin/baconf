
#!/bin/bash
#Make subdirectories
mkdir -p /mnt/backup/Arch/.config
mkdir -p /mnt/backup/Arch/.kde4/share/apps

#Config dirs
rsync -av --delete ~/.config/chromium/Default /mnt/backup/Arch/.config/chromium/
rsync -av --delete ~/.config/libreoffice /mnt/backup/Arch/.config/
rsync -av --delete ~/.config/mc /mnt/backup/Arch/.config/
rsync -av --delete ~/.config/Trolltech.conf /mnt/backup/Arch/.config/
#Dmenu + zsh history :)
rsync -av --delete ~/.dmenu_history /mnt/backup/Arch/
rsync -av --delete ~/.zsh_history /mnt/backup/Arch/
#Vim spelling
rsync -av --delete ~/.vim/spell /mnt/backup/Arch/.vim/
#KDE4 config
rsync -av --delete ~/.kde4/share/apps/okular/part.rc /mnt/backup/Arch/.kde4/share/apps/okular/
#SSH keys
rsync -av --delete ~/.ssh /mnt/backup/Arch/
#Just lazy to log in into Anki again :)
rsync -av --delete ~/Anki /mnt/backup/Arch/

#Hourly backup
if [[ ! -f /mnt/backup/Hourly/`date +%Y`/`date +%b`/`date +%d.%H`.tgz ]]; then
    mkdir -p /mnt/backup/Hourly/`date +%Y`/`date +%b`
    tar -cpzvf /mnt/backup/Hourly/`date +%Y`/`date +%b`/`date +%d.%H`.tgz /mnt/backup/Arch
fi
#Daily backup to ~/Copy
if [[ ! -f ~/Copy/Backup/Arch`date +%Y.%b.%d`.tgz ]]; then
    tar -cpzvf ~/Copy/Backup/Arch`date +%Y.%b.%d`.tgz /mnt/backup/Arch
fi

#BTP backup to ~/Copy
rsync -av --delete ~/btp ~/Copy/

#Synchronize drives
sync
