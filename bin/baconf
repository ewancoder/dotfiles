#!/bin/bash
rsync -av --delete ~/.config/chromium /mnt/backup/ArchConfig/
rsync -av --delete ~/.config/deluge /mnt/backup/ArchConfig/
rsync -av --delete ~/.config/libreoffice /mnt/backup/ArchConfig/
rsync -av --delete ~/.config/mc /mnt/backup/ArchConfig/
#Thunar config is located here
rsync -av --delete ~/.config/xfce4 /mnt/backup/ArchConfig/
#User-defined actions for Thunar
rsync -av --delete ~/.config/Thunar /mnt/backup/ArchConfig/

#For connecting to raspberry PI automatically after reinstall
rsync -av --delete ~/.ssh /mnt/backup/Arch/
#XboomX history + zsh history :)
rsync -av --delete ~/.xboomx /mnt/backup/Arch/
rsync -av --delete ~/.zsh_history /mnt/backup/Arch/
#Just lazy to log in into Anki again :)
rsync -av --delete ~/Anki /mnt/backup/Arch/

if [[ ! -d /mnt/backup/Hourly/$(date +%Y)/$(date +%b) ]]; then
    mkdir -p /mnt/backup/Hourly/$(date +%Y)/$(date +%b)
fi

if [[ ! -f /mnt/backup/Hourly/$(date +%Y)/$(date +%b)/$(date +%d.%H).tgz ]]; then
    tar -cpzvf /mnt/backup/Hourly/$(date +%Y)/$(date +%b)/$(date +%d.%H).tgz /mnt/backup/Arch
fi

if [[ ! -f ~/Copy/Backup/Arch$(date +%Y.%b.%d).tgz ]]; then
    tar -cpzvf ~/Copy/Backup/Arch$(date +%Y.%b.%d).tgz /mnt/backup/Arch
fi
