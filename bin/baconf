#!/bin/bash
#Lockfile section
while [ -f /tmp/baconf.lock ]; do
    echo "Lock file is exists. Waiting for previous copy of baconf to shutdown [10 seconds]..."
    sleep 10
done
touch /tmp/baconf.lock

#Make subdirectories
mkdir -p /mnt/backup/Arch/.config
mkdir -p /mnt/backup/Arch/.kde4/share/apps
mkdir -p /mnt/backup/Arch/.local/share/vlc/lua

#VLC extensions
rsync -av --delete ~/.local/share/vlc/lua/extensions /mnt/backup/Arch/.local/share/vlc/lua/

#Config dirs
rsync -av --delete ~/.config/chromium/Default /mnt/backup/Arch/.config/chromium/
rsync -av --delete ~/.config/deluge /mnt/backup/Arch/.config/
rsync -av --delete ~/.config/libreoffice /mnt/backup/Arch/.config/
rsync -av --delete ~/.config/mc /mnt/backup/Arch/.config/
rsync -av --delete ~/.config/Popcorn-Time /mnt/backup/Arch/.config/
rsync -av --delete ~/.config/Trolltech.conf /mnt/backup/Arch/.config/
rsync -av --delete ~/.config/vlc /mnt/backup/Arch/.config/
#Dmenu + zsh history :)
rsync -av --delete ~/.dmenu_history /mnt/backup/Arch/
rsync -av --delete ~/.zsh_history /mnt/backup/Arch/
#Vim spelling
rsync -av --delete ~/.vim/spell /mnt/backup/Arch/.vim/
#KDE4 config
rsync -av --delete ~/.kde4/share/apps/okular/part.rc /mnt/backup/Arch/.kde4/share/apps/okular/
#SSH keys
rsync -av --delete ~/.ssh /mnt/backup/Arch/
#Just lazy to log in into Anki again :)
rsync -av --delete ~/Anki /mnt/backup/Arch/
#WizNote
rsync -av --delete ~/.wiznote /mnt/backup/Arch/

#Hourly backup
if [[ ! -f /mnt/backup/Hourly/`date +%Y`/`date +%b`/Note`date +%d.%H`.tgz ]]; then
    mkdir -p /mnt/backup/Hourly/`date +%Y`/`date +%b`
    tar -cpzvf /mnt/backup/Hourly/`date +%Y`/`date +%b`/Note`date +%d.%H`.tgz /mnt/backup/Arch
    if [[ ! -f ~/Copy/Backup/NoteArch`date +%Y.%b.%d`.tgz ]]; then
        cp /mnt/backup/Hourly/`date +%Y`/`date +%b`/`date +%d.%H`.tgz ~/Copy/Backup/NoteArch`date +%Y.%b.%d`.tgz
    fi
fi

#Backup GIT Projects to ~/Copy
rsync -av ~/btp ~/Copy/Projects/Notebook/
rsync -av ~/site ~/Copy/Projects/Notebook/
rsync -av ~/eal ~/Copy/Projects/Notebook/

#Synchronize drives
sync

#Remove lockfile
rm /tmp/baconf.lock
