#!/bin/bash
ready=0

if [ "$1" == "-r" -o "$2" == "-r" -o "$3" == "-r" -o "$1" == "-ro" -o "$1" == "-or" -o "$2" == "-ro" -o "$2" == "-or" ]; then
    ready=1
fi

mkdir -p .build
ln -fs ../beamer.tex ../beamer.tex

build(){
    cd .build
    ln -fs ../*.tex .
    ln -fs ../Figures ../Figures
    pdflatex -shell-escape main
    pdflatex -shell-escape main
    cd ..
}

build
mv .build/main.pdf `basename $PWD`.pdf

if [ $ready -eq 1 ]; then
    mv *.pdf ~/Dropbox/Print
fi

rm -r .build ../beamer.tex Figures
