438\u043b\u0430\u0441\u044c. \u041d\u043e! \u041f\u0440\u043e\u0431\u043b\u0435\u043c\u0430 \u0432 \u0442\u043e\u043c, \u0447\u0442\u043e \u0434\u043e\u043a\u0430\u0437\u0430\u0442\u0435\u043b\u044c\u0441\u0442\u0432\u0430 \u0440\u0435\u0448\u0435\u043d\u0438\u044f \u0441\u0430\u043c\u0438 \u043f\u043e \u0441\u0435\u0431\u0435 \u0437\u0430\u043d\u0438\u043c\u0430\u044e\u0442 13 \u0413\u0431 (\u0435\u0449\u0435 \u0440\u0430\u0437, \u0442\u0435\u043a\u0441\u0442\u043e\u0432\u044b\u0439 \u043b\u043e\u0433-\u0444\u0430\u0439\u043b, \u043f\u043e \u0441\u0443\u0442\u0438 \u0438 \u044f\u0432\u043b\u044f\u044e\u0449\u0438\u0439\u0441\u044f \u0434\u043e\u043a\u0430\u0437\u0430\u0442\u0435\u043b\u044c\u0441\u0442\u0432\u043e\u043c, \u0437\u0430\u043d\u0438\u043c\u0430\u0435\u0442 13 \u0413\u0431) \u0438 \u0441 \u0442\u0440\u0443\u0434\u043e\u043c \u043f\u043e\u0434\u0434\u0430\u0435\u0442\u0441\u044f \u0432\u0435\u0440\u0438\u0444\u0438\u043a\u0430\u0446\u0438\u0438. \u041e\u0442\u0441\u044e\u0434\u0430 \u043d\u0430\u043f\u0440\u0430\u0448\u0438\u0432\u0430\u0435\u0442\u0441\u044f \u043f\u0440\u043e\u0441\u0442\u043e\u0439 \u0432\u043e\u043f\u0440\u043e\u0441 \u2013 \u043c\u043e\u0436\u0435\u043c \u043b\u0438 \u043c\u044b \u0434\u043e\u0432\u0435\u0440\u044f\u0442\u044c \u0440\u0435\u0448\u0435\u043d\u0438\u044e \u043a\u043e\u043c\u043f\u044c\u044e\u0442\u0435\u0440\u0430, \u0435\u0441\u043b\u0438 \u043d\u0435 \u0432 \u0441\u043e\u0441\u0442\u043e\u044f\u043d\u0438\u0438 \u043f\u0440\u043e\u0432\u0435\u0440\u0438\u0442\u044c \u0435\u0433\u043e \u0432\u044b\u043a\u043b\u0430\u0434\u043a\u0438?<br />\u000a<br />\u000a<img src="http://habrastorage.org/getpro/habr/post_images/908/7cb/483/9087cb483b16996d14b142f23e7c7b44.jpg" /><br />\u000a <a href="http://habrahabr.ru/post/214229/#habracut">\u0427\u0438\u0442\u0430\u0442\u044c \u0434\u0430\u043b\u044c\u0448\u0435 &rarr;</a>
