e\u0442\u043e\u0439 \u043a\u0430\u0434\u0440\u043e\u0432. \u0422\u0435\u043f\u0435\u0440\u044c \u044d\u0442\u043e \u043e\u0433\u0440\u0430\u043d\u0438\u0447\u0435\u043d\u0438\u0435 \u0443\u0441\u0442\u0440\u0430\u043d\u0435\u043d\u043e, \u0438 \u043d\u043e\u0432\u0443\u044e \u043a\u0430\u043c\u0435\u0440\u0443 Drift HD Ghost-S \u0441 \u0432\u043e\u0437\u043c\u043e\u0436\u043d\u043e\u0441\u0442\u044c\u044e \u0437\u0430\u043f\u0438\u0441\u0438 \u0432\u0438\u0434\u0435\u043e 1920&#215;1080 60p \u043c\u043e\u0436\u043d\u043e \u0441\u0447\u0438\u0442\u0430\u0442\u044c \u0441\u0435\u0440\u044c\u0435\u0437\u043d\u044b\u043c \u043a\u043e\u043d\u043a\u0443\u0440\u0435\u043d\u0442\u043e\u043c \u043c\u043d\u043e\u0433\u0438\u043c \u043f\u0440\u043e\u0447\u0438\u043c \u044d\u043a\u0448\u043d-\u0430\u043f\u043f\u0430\u0440\u0430\u0442\u0430\u043c.
