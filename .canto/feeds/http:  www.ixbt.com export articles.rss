\u044b\u0439 \u0432\u043d\u0435\u0448\u043d\u0438\u0439 \u0432\u0438\u0434, \u0431\u043e\u043b\u0435\u0435 \u0447\u0435\u043c \u0441\u043a\u0440\u043e\u043c\u043d\u043e\u0435 \u0432\u0440\u0435\u043c\u044f \u0430\u0432\u0442\u043e\u043d\u043e\u043c\u043d\u043e\u0439 \u0440\u0430\u0431\u043e\u0442\u044b \u2014 \u0432\u0441\u0435 \u044d\u0442\u043e \u0433\u043e\u0432\u043e\u0440\u0438\u0442 \u043d\u0435 \u0432 \u043f\u043e\u043b\u044c\u0437\u0443 \u0433\u0435\u0440\u043e\u044f \u0441\u0435\u0433\u043e\u0434\u043d\u044f\u0448\u043d\u0435\u0433\u043e \u043e\u0431\u0437\u043e\u0440\u0430. \u041e\u0434\u043d\u0430\u043a\u043e \u043d\u0435\u0432\u0435\u043b\u0438\u043a\u0430 \u0438 \u0446\u0435\u043d\u0430 \u2014 \u043f\u043e \u043a\u0440\u0430\u0439\u043d\u0435\u0439 \u043c\u0435\u0440\u0435, \u043e\u043d\u0430 \u0437\u043d\u0430\u0447\u0438\u0442\u0435\u043b\u044c\u043d\u043e \u043d\u0438\u0436\u0435, \u0447\u0435\u043c \u0443 \u0431\u043e\u043b\u044c\u0448\u0438\u043d\u0441\u0442\u0432\u0430 \u0441\u043e\u0432\u0440\u0435\u043c\u0435\u043d\u043d\u044b\u0445 ｫ\u043b\u043e\u043f\u0430\u0442\u043e\u0444\u043e\u043d\u043e\u0432ｻ \u0441 \u044d\u043a\u0440\u0430\u043d\u043e\u043c \u0431\u043e\u043b\u044c\u0448\u0435 6 \u0434\u044e\u0439\u043c\u043e\u0432. \u0410 \u0432\u043e\u0437\u043c\u043e\u0436\u043d\u043e\u0441\u0442\u044c \u0441\u044d\u043a\u043e\u043d\u043e\u043c\u0438\u0442\u044c \u0437\u0430\u0441\u0442\u0430\u0432\u043b\u044f\u0435\u0442 \u0438\u043d\u043e\u0433\u0434\u0430 \u0437\u0430\u043a\u0440\u044b\u0442\u044c \u0433\u043b\u0430\u0437\u0430 \u043d\u0430 \u043c\u043d\u043e\u0433\u0438\u0435 \u043d\u0435\u0434\u043e\u0441\u0442\u0430\u0442\u043a\u0438, \u043e\u0441\u043e\u0431\u0435\u043d\u043d\u043e \u0435\u0441\u043b\u0438 \u043f\u043e\u043a\u0443\u043f\u0430\u0442\u0435\u043b\u044c \u043e\u0433\u0440\u0430\u043d\u0438\u0447\u0435\u043d \u0432 \u0441\u0440\u0435\u0434\u0441\u0442\u0432\u0430\u0445.
