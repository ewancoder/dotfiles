0435\u043c\u044b\u0445 \u043c\u0430\u0442\u0435\u0440\u0438\u0430\u043b\u043e\u0432 \u0438\u043b\u0438 \u043a\u0430\u0447\u0435\u0441\u0442\u0432\u043e \u0441\u0431\u043e\u0440\u043a\u0438. \u0425\u043e\u0442\u044f, \u043a\u043e\u043d\u0435\u0447\u043d\u043e, \u043d\u0435 \u043e\u0431\u043e\u0448\u043b\u043e\u0441\u044c \u0438 \u0431\u0435\u0437 \u0434\u043e\u0441\u0430\u0434\u043d\u044b\u0445 \u043c\u0438\u043d\u0443\u0441\u043e\u0432: \u0430\u043f\u043f\u0430\u0440\u0430\u0442 \u043f\u043e\u043b\u043d\u043e\u0441\u0442\u044c\u044e \u043b\u0438\u0448\u0435\u043d \u043a\u0430\u043a\u043e\u0439 \u0431\u044b \u0442\u043e \u043d\u0438 \u0431\u044b\u043b\u043e \u0432\u043e\u0437\u043c\u043e\u0436\u043d\u043e\u0441\u0442\u0438 \u0440\u0430\u0441\u0448\u0438\u0440\u0435\u043d\u0438\u044f \u043e\u0431\u044a\u0435\u043c\u0430 \u043f\u0430\u043c\u044f\u0442\u0438 \u2014 \u043d\u0438 \u0441 \u043f\u043e\u043c\u043e\u0449\u044c\u044e \u043a\u0430\u0440\u0442\u043e\u0447\u0435\u043a \u043f\u0430\u043c\u044f\u0442\u0438, \u043d\u0438 \u043f\u043e\u0434\u043a\u043b\u044e\u0447\u0435\u043d\u0438\u0435\u043c \u0432\u043d\u0435\u0448\u043d\u0435\u0433\u043e \u0444\u043b\u044d\u0448-\u043d\u0430\u043a\u043e\u043f\u0438\u0442\u0435\u043b\u044f \u0447\u0435\u0440\u0435\u0437 OTG-\u043f\u0435\u0440\u0435\u0445\u043e\u0434\u043d\u0438\u043a. \u0422\u0435\u043c \u043d\u0435 \u043c\u0435\u043d\u0435\u0435, \u0441\u043c\u0430\u0440\u0442\u0444\u043e\u043d \u043f\u0440\u0438 \u0442\u0430\u043a\u043e\u0439 \u043d\u0435\u0432\u044b\u0441\u043e\u043a\u043e\u0439 \u043e\u0442\u043f\u0443\u0441\u043a\u043d\u043e\u0439 \u0441\u0442\u043e\u0438\u043c\u043e\u0441\u0442\u0438 \u0432 \u043b\u044e\u0431\u043e\u043c \u0441\u043b\u0443\u0447\u0430\u0435 \u044f\u0432\u043b\u044f\u0435\u0442\u0441\u044f \u0432\u0435\u0441\u044c\u043c\u0430 \u0438\u043d\u0442\u0435\u0440\u0435\u0441\u043d\u044b\u043c \u0431\u044e\u0434\u0436\u0435\u0442\u043d\u044b\u043c \u0430\u043f\u043f\u0430\u0440\u0430\u0442\u043e\u043c, \u0447\u0435\u043c \u0432\u043f\u043e\u043b\u043d\u0435 \u043e\u0442\u0432\u0435\u0447\u0430\u0435\u0442 \u0443\u0440\u043e\u0432\u043d\u044e ｫ\u043f\u0440\u043e\u0434\u0443\u043a\u0442\u0430 \u0434\u043b\u044f \u0441\u043f\u043e\u043d\u0442\u0430\u043d\u043d\u043e\u0439 \u043f\u043e\u043a\u0443\u043f\u043a\u0438ｻ, \u0430 \u044d\u0442\u043e \u0437\u043d\u0430\u0447\u0438\u0442, \u0447\u0442\u043e \u043d\u0435\u043f\u043b\u043e\u0445\u0438\u0435 \u043f\u0440\u043e\u0434\u0430\u0436\u0438 \u0443\u0441\u0442\u0440\u043e\u0439\u0441\u0442\u0432\u0443 \u0432 \u0431\u044e\u0434\u0436\u0435\u0442\u043d\u043e\u043c \u0441\u0435\u0433\u043c\u0435\u043d\u0442\u0435 \u043e\u0431\u0435\u0441\u043f\u0435\u0447\u0435\u043d\u044b.
