V<img src="http://www.ixbt.com//articles/pics2/201402/gopro-hero-3plus-be_115x115.jpg" align="left" hspace="20" />\u0422\u043e\u0447\u043d\u043e \u0442\u0430\u043a, \u043a\u0430\u043a \u0432 \u0441\u0432\u043e\u0435 \u0432\u0440\u0435\u043c\u044f Xerox \u043f\u0440\u0435\u0432\u0440\u0430\u0442\u0438\u043b\u0441\u044f \u0432 \u043a\u0441\u0435\u0440\u043e\u043a\u0441, GoPro \u0434\u0430\u0432\u043d\u043e \u0441\u0442\u0430\u043b\u043e \u0438\u043c\u0435\u043d\u0435\u043c \u043d\u0430\u0440\u0438\u0446\u0430\u0442\u0435\u043b\u044c\u043d\u044b\u043c \u0432 \u0441\u0440\u0435\u0434\u0435 \u044d\u043a\u0448\u043d-\u0441\u044a\u0435\u043c\u043a\u0438, \u0441\u043f\u043e\u0440\u0438\u0442\u044c \u0441 \u044d\u0442\u0438\u043c \u0443\u0442\u0432\u0435\u0440\u0436\u0434\u0435\u043d\u0438\u0435\u043c \u043d\u0435 \u0438\u043c\u0435\u0435\u0442 \u0441\u043c\u044b\u0441\u043b\u0430. \u0412 \u043f\u0440\u043e\u0448\u043b\u043e\u043c \u0433\u043e\u0434\u0443 \u043f\u0440\u0438\u0432\u0435\u0440\u0436\u0435\u043d\u0446\u044b \u0430\u043a\u0442\u0438\u0432\u043d\u043e\u0433\u043e \u043e\u0431\u0440\u0430\u0437\u0430 \u0436\u0438\u0437\u043d\u0438 \u043d\u0435 \u043c\u0435\u043d\u0435\u0435 \u0430\u043a\u0442\u0438\u0432\u043d\u043e \u0440\u0430\u0434\u043e\u0432\u0430\u043b\u0438\u0441\u044c \u043f\u043e\u044f\u0432\u043b\u0435\u043d\u0438\u044e \u043a\u0430\u0440\u0434\u0438\u043d\u0430\u043b\u044c\u043d\u043e \u043f\u0435\u0440\u0435\u0440\u0430\u0431\u043e\u0442\u0430\u043d\u043d\u043e\u0439 \u0432\u0435\u0440\u0441\u0438\u0438 \u043b\u044e\u0431\u0438\u043c\u043e\u0433\u043e \u0432\u0438\u0434\u0435\u043e\u0433\u0430\u0434\u0436\u0435\u0442\u0430 \u2014 GoPro Hero 3. \u042d\u0442\u0430 \u043a\u0430\u0440\u0434\u0438\u043d\u0430\u043b\u044c\u043d\u043e\u0441\u0442\u044c \u0437\u0430\u043a\u043b\u044e\u0447\u0430\u043b\u0430\u0441\u044c, \u043f\u043e\u0436\u0430\u043b\u0443\u0439, \u0432\u043e \u0432\u0441\u0435\u043c: \u043e\u0442 \u043f\u043e\u044f\u0432\u043b\u0435\u043d\u0438\u044f \u0440\u0435\u0436\u0438\u043c\u0430 \u0437\u0430\u043f\u0438\u0441\u0438 4K \u0434\u043e \u0443\u043c\u0435\u043d\u044c\u0448\u0435\u043d\u0438\u044f \u0433\u0430\u0431\u0430\u0440\u0438\u0442\u043e\u0432 \u0430\u043f\u043f\u0430\u0440\u0430\u0442\u0430. \u041f\u0440\u043e\u0448\u0435\u043b \u0433\u043e\u0434, \u0438 \u0433\u043b\u0443\u043f\u043e \u0434\u0443\u043c\u0430\u0442\u044c, \u0447\u0442\u043e \u043a\u043e\u043c\u0430\u043d\u0434\u0430 \u0440\u0430\u0437\u0440\u0430\u0431\u043e\u0442\u0447\u0438\u043a\u043e\u0432 \u0441\u0438\u0434\u0435\u043b\u0430 \u0432\u0441\u0435 \u044d\u0442\u043e \u0432\u0440\u0435\u043c\u044f \u0441\u043b\u043e\u0436\u0430 \u0440\u0443\u043a\u0438, \u043f\u043e\u0436\u0438\u043d\u0430\u044f \u043f\u043b\u043e\u0434\u044b \u0441\u0434\u0435\u043b\u0430\u043d\u043d\u043e\u0439 \u0440\u0430\u0431\u043e\u0442\u044b. \u041a\u043e\u043d\u0435\u0447\u043d\u043e \u043d\u0435\u0442. \u041e\u043d\u0438 \u0442\u0440\u0443\u0434\u0438\u043b\u0438\u0441\u044c, \u043d\u0435\u0441\u043e\u043c\u043d\u0435\u043d\u043d\u043e. \u0412 \u0440\u0435\u0437\u0443\u043b\u044c\u0442\u0430\u0442\u0435 \u0447\u0435\u0433\u043e \u043d\u0430 \u0441\u0432\u0435\u0442 \u043f\u043e\u044f\u0432\u0438\u043b\u0430\u0441\u044c (\u0442\u0435\u043f\u0435\u0440\u044c \u0435\u0449\u0435 \u0438 \u0432 \u043d\u0430\u0448\u0435\u0439 \u0441\u0442\u0440\u0430\u043d\u0435) \u043e\u0431\u043d\u043e\u0432\u043b\u0435\u043d\u043d\u0430\u044f \u0432\u0435\u0440\u0441\u0438\u044f \u0442\u043e\u0439, \u043f\u0440\u0435\u0436\u043d\u0435\u0439 ｫ\u0442\u0440\u043e\u0435\u0447\u043a\u0438ｻ, \u043e\u0431\u043e\u0437\u043d\u0430\u0447\u0435\u043d\u043d\u0430\u044f \u043a\u0430\u043a Hero 3+. \u041f\u043e\u0447\u0435\u043c\u0443 \u0436\u0435 \u043d\u043e\u0432\u0430\u044f \u043c\u043e\u0434\u0435\u043b\u044c \u043d\u0435 \u043f\u0440\u0438\u0431\u0430\u0432\u0438\u043b\u0430 \u043e\u0447\u0435\u0440\u0435\u0434\u043d\u0443\u044e \u0446\u0438\u0444\u0440\u0443 \u043a \u0441\u0432\u043e\u0435\u043c\u0443 \u043d\u0430\u0437\u0432\u0430\u043d\u0438\u044e? \u041d\u0435\u0434\u043e\u0441\u0442\u0430\u0442\u043e\u0447\u043d\u043e \u043a\u043e\u043b\u0438\u0447\u0435\u0441\u0442\u0432\u0435\u043d\u043d\u044b\u0445 \u0438 \u043a\u0430\u0447\u0435\u0441\u0442\u0432\u0435\u043d\u043d\u044b\u0445 \u0438\u0437\u043c\u0435\u043d\u0435\u043d\u0438\u0439? \u041f\u043e\u043f\u0440\u043e\u0431\u0443\u0435\u043c \u0440\u0430\u0437\u043e\u0431\u0440\u0430\u0442\u044c\u0441\u044f.
