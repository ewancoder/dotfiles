V<p><a href="http://auto.onliner.by/2014/02/27/peregon"><img src="http://content.onliner.by/news/2014/02/thumbnail/ee6617b6276c4141737d047cc3fc2215.jpg" alt="" /></a></p><p>\u0423\u0440\u0430\u0432\u043d\u0438\u0432\u0430\u043d\u0438\u0435 \u043f\u043e\u0448\u043b\u0438\u043d \u0432 \u0441\u0442\u0440\u0430\u043d\u0430\u0445 \u0422\u0430\u043c\u043e\u0436\u0435\u043d\u043d\u043e\u0433\u043e \u0441\u043e\u044e\u0437\u0430 \u0444\u0430\u043a\u0442\u0438\u0447\u0435\u0441\u043a\u0438 \u0441\u0432\u0435\u043b\u043e \u043d\u0430 \u043d\u0435\u0442 \u043d\u0435\u043a\u043e\u0433\u0434\u0430 \u0434\u043e\u0445\u043e\u0434\u043d\u044b\u0439, \u0440\u0430\u0441\u043a\u0440\u0443\u0447\u0435\u043d\u043d\u044b\u0439 \u0431\u0438\u0437\u043d\u0435\u0441 \u043f\u0435\u0440\u0435\u0433\u043e\u043d\u0430 \u0430\u0432\u0442\u043e\u043c\u043e\u0431\u0438\u043b\u0435\u0439. \u0422\u0430\u043c\u043e\u0436\u0435\u043d\u043d\u0438\u043a\u0438 \u043f\u043e\u0434\u0441\u0447\u0438\u0442\u0430\u043b\u0438: \u0447\u0435\u0440\u0435\u0437 \u043f\u0443\u043d\u043a\u0442\u044b \u043f\u0440\u043e\u043f\u0443\u0441\u043a\u0430 \u0442\u043e\u043b\u044c\u043a\u043e \u0411\u0440\u0435\u0441\u0442\u0441\u043a\u043e\u0439 \u043e\u0431\u043b\u0430\u0441\u0442\u0438 \u0441 \u0438\u044e\u043b\u044f 2011-\u0433\u043e \u043f\u043e \u0438\u044e\u043d\u044c 2012-\u0433\u043e \u0432\u0432\u0435\u0437\u043b\u0438 \u0447\u0443\u0442\u044c \u0431\u043e\u043b\u0435\u0435 9 \u0442\u044b\u0441\u044f\u0447 \u0430\u0432\u0442\u043e\u043c\u043e\u0431\u0438\u043b\u0435\u0439. \u0410 \u0432\u043e\u0442 \u0437\u0430 \u0433\u043e\u0434, \u043f\u0440\u0435\u0434\u0448\u0435\u0441\u0442\u0432\u0443\u044e\u0449\u0438\u0439 \u043f\u043e\u0432\u044b\u0448\u0435\u043d\u0438\u044e \u0441\u0442\u043e\u0438\u043c\u043e\u0441\u0442\u0438 \u0440\u0430\u0441\u0442\u0430\u043c\u043e\u0436\u043a\u0438, \u043d\u0430 \u0411\u0440\u0435\u0441\u0442\u0447\u0438\u043d\u0443 \u043f\u0440\u0438\u0433\u043d\u0430\u043b\u0438 \u0441\u0440\u0430\u0437\u0443 80 \u0442\u044b\u0441\u044f\u0447 \u043c\u0430\u0448\u0438\u043d. \u041f\u043e \u0441\u043b\u043e\u0432\u0430\u043c \u0431\u044b\u0432\u0448\u0435\u0433\u043e \u043f\u0435\u0440\u0435\u0433\u043e\u043d\u0449\u0438\u043a\u0430 \u0438\u0437 \u0411\u0440\u0435\u0441\u0442\u0430, \u0441\u0435\u0439\u0447\u0430\u0441 \u0437\u0430\u043f\u0440\u043e\u0441\u044b \u0431\u0435\u043b\u043e\u0440\u0443\u0441\u043e\u0432 \u0432 \u043e\u0441\u043d\u043e\u0432\u043d\u043e\u043c \u0443\u0434\u043e\u0432\u043b\u0435\u0442\u0432\u043e\u0440\u0435\u043d\u044b: \u0442\u0440\u0438 \u0433\u043e\u0434\u0430 \u043d\u0430\u0437\u0430\u0434 \u043c\u043d\u043e\u0433\u0438\u0435 \u043f\u0440\u0438\u0433\u043e\u043d\u044f\u043b\u0438 \u043f\u043e \u0434\u0432\u0435-\u0442\u0440\u0438 \u0434\u043e\u0431\u0440\u043e\u0442\u043d\u044b\u0435 \u043c\u0430\u0448\u0438\u043d\u044b \u0441 \u043d\u0430\u0434\u0435\u0436\u0434\u043e\u0439, \u0447\u0442\u043e \u0438\u0445 \u0445\u0432\u0430\u0442\u0438\u0442 \u043d\u0430 \u0431\u043b\u0438\u0436\u0430\u0439\u0448\u0438\u0435 \u043f\u044f\u0442\u044c-\u0434\u0435\u0441\u044f\u0442\u044c \u043b\u0435\u0442. \u041a\u0440\u0435\u0434\u0438\u0442\u044b \u0442\u043e\u0433\u0434\u0430 \u0431\u044b\u043b\u0438 \u0434\u043e\u0441\u0442\u0443\u043f\u043d\u0435\u0435, \u0442\u043e\u043f\u043b\u0438\u0432\u043e \u0434\u0435\u0448\u0435\u0432\u043b\u0435, \u0430 \u0437\u043d\u0430\u0447\u0438\u0442, \u043f\u043e\u043a\u0443\u043f\u043a\u0430 \u043c\u0430\u0448\u0438\u043d\u044b \u043d\u0435 \u0432\u044b\u043b\u0438\u0432\u0430\u043b\u0430\u0441\u044c \u0432 \u0441\u0435\u0440\u044c\u0435\u0437\u043d\u044b\u0435 \u0437\u0430\u0442\u0440\u0430\u0442\u044b. \u041f\u043e\u0442\u043e\u043c \u0432\u0441\u0435 \u0438\u0437\u043c\u0435\u043d\u0438\u043b\u043e\u0441\u044c.</p><p><a href="http://auto.onliner.by/2014/02/27/peregon">\u0427\u0438\u0442\u0430\u0442\u044c \u0434\u0430\u043b\u0435\u0435\u2026</a></p>
