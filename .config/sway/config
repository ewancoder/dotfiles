# Load machine-specific config
include machine

font pango:monospace 8
titlebar_padding 5 1
gaps inner 0
gaps outer 0

set $mod Mod4

set $opacity 0.9
set $left h
set $down t
set $up c
set $right n

set $term foot
set $menu fuzzel --no-icons --no-exit-on-keyboard-focus-loss | xargs swaymsg exec --

#bindsym $mod+tab output 'DP-2' toggle; output 'DP-1' toggle

input type:keyboard {
    xkb_layout us,ru
    xkb_variant dvorak,
    #xkb_options grp:win_space_toggle
}

bindsym $mod+space input type:keyboard xkb_switch_layout next

# Start a terminal
bindsym $mod+Return exec $term

# Kill focused window
bindsym $mod+q kill

# Start your launcher
bindsym $mod+m exec $menu

bindsym $mod+p exec grim -g "$(slurp)" - | wl-copy
bindsym $mod+Shift+p exec grim - | wl-copy
bindsym $mod+y exec grim -g "$(slurp)" - | swappy -f - | wl-copy

# Dismiss all notifications
bindsym $mod+escape exec makoctl dismiss -a

# Moving windows
floating_modifier $mod normal

# Exit sway (logs you out of your Wayland session)
bindsym $mod+Shift+e exec swaynag -t warning -m 'Exit?' -B 'Yes, exit sway' 'swaymsg exit'

# Move your focus around
bindsym $mod+$left focus left
bindsym $mod+$down focus down
bindsym $mod+$up focus up
bindsym $mod+$right focus right

# Move the focused window with the same, but add Shift
bindsym $mod+Shift+$left move left
bindsym $mod+Shift+$down move down
bindsym $mod+Shift+$up move up
bindsym $mod+Shift+$right move right

# Switch to workspace
bindsym $mod+1 workspace 4:fun
bindsym $mod+2 workspace 5:work
bindsym $mod+3 workspace 6:med
bindsym $mod+apostrophe workspace 1:left-fun
bindsym $mod+comma workspace 2:left-work
bindsym $mod+period workspace 3:left-med
bindsym $mod+a workspace 7:right-fun
bindsym $mod+o workspace 8:right-work
bindsym $mod+semicolon workspace 9:right-med
bindsym $mod+9 workspace trash

bindsym $mod+Control+Left workspace 4:fun
bindsym $mod+Control+Right workspace 5:work

# Move to workspace
bindsym $mod+Shift+1 move container to workspace 4:fun
bindsym $mod+Shift+2 move container to workspace 5:work
bindsym $mod+Shift+3 move container to workspace 6:med
bindsym $mod+Shift+apostrophe move container to workspace 1:left-fun
bindsym $mod+Shift+comma move container to workspace 2:left-work
bindsym $mod+Shift+period move container to workspace 3:left-med
bindsym $mod+Shift+a move container to workspace 7:right-fun
bindsym $mod+Shift+o move container to workspace 8:right-work
bindsym $mod+Shift+semicolon move container to workspace 9:right-med
bindsym $mod+Shift+9 move container to workspace trash



# Split vertically or horizontally
bindsym $mod+b splith
bindsym $mod+v splitv

# Different layouts for current container
bindsym $mod+s layout stacking
bindsym $mod+w layout tabbed
bindsym $mod+e layout toggle split

# Make the current focus fullscreen
bindsym $mod+f fullscreen

# Toggle the current focus between tiling and floating mode
bindsym $mod+Shift+space floating toggle
bindsym $mod+BackSpace floating toggle

# Swap focus between the tiling area and the floating area
#bindsym $mod+space focus mode_toggle

# Move focus to the parent container
#bindsym $mod+a focus parent

# Move the currently focused window to the scratchpad
bindsym $mod+Shift+minus move scratchpad

# Show the next scratchpad window or hide the focused scratchpad window.
# If there are multiple scratchpad windows, this command cycles through them.
bindsym $mod+minus scratchpad show

bindsym $mod+l exec curl -X POST http://localhost:8080/api/v2/transfer/toggleSpeedLimitsMode
bindsym $mod+shift+l exec swaylock

bindsym $mod+grave exec swaymsg "[con_id=$(swaymsg -t get_tree | jq -r '.. | select(.focused? == true) | .id')]" opacity 0.8
bindsym $mod+shift+grave exec swaymsg "[con_id=$(swaymsg -t get_tree | jq -r '.. | select(.focused? == true) | .id')]" opacity 1
bindsym $mod+ctrl+grave exec swaymsg "[con_id=$(swaymsg -t get_tree | jq -r '.. | select(.focused? == true) | .id')]" opacity 0.4

# Resizing (mod+r)
bindsym $mod+r mode "resize"
mode "resize" {
    bindsym $left resize grow width 100px
    bindsym $down resize shrink height 100px
    bindsym $up resize grow height 100px
    bindsym $right resize shrink width 100px

    # Return to default mode
    bindsym Return mode "default"
    bindsym Escape mode "default"
}

# Special keys to adjust volume via PulseAudio
bindsym --locked XF86AudioMute exec pactl set-sink-mute \@DEFAULT_SINK@ toggle
bindsym --locked XF86AudioLowerVolume exec pactl set-sink-volume \@DEFAULT_SINK@ -5%
bindsym --locked XF86AudioRaiseVolume exec pactl set-sink-volume \@DEFAULT_SINK@ +5%
bindsym --locked XF86AudioMicMute exec pactl set-source-mute \@DEFAULT_SOURCE@ toggle
bindsym --locked XF86AudioPrev exec playerctl previous
bindsym --locked XF86AudioNext exec playerctl next
bindcode 172 exec playerctl play-pause

# Special keys to adjust brightness via brightnessctl
bindsym --locked XF86MonBrightnessDown exec brightnessctl set 5%-
bindsym --locked XF86MonBrightnessUp exec brightnessctl set 5%+

# Special key to take a screenshot with grim
bindsym Print exec grim

# Status bar
bar {
    mode hide
    modifier alt
    position top
    output DP-3
    output DP-1
    output eDP-1
    output HDMI-A-1
    output HDMI-A-3

    status_command ~/.local/bin/status.sh

    colors {
        statusline #ffe680
        background #282828ee
        inactive_workspace #28282800 #28282800 #7c6f64
        focused_workspace #28282800 #d65d0eaa #fbf1c7
    }

    tray_padding 2
    font pango:DejaVu Sans Mono 10
    separator_symbol "  "
}

bar {
    position top
    output DP-4

    status_command ~/.local/bin/status.sh

    colors {
        statusline #ffe680
        background #282828ee
        inactive_workspace #28282800 #28282800 #7c6f64
        focused_workspace #28282800 #d65d0eaa #fbf1c7
    }

    tray_padding 2
    font pango:DejaVu Sans Mono 10
    separator_symbol "  "
}

bar {
    position top
    mode dock
    output DP-5

    status_command ~/.local/bin/status-music.sh

    colors {
        statusline #ffe680
        background #282828ee
        inactive_workspace #28282800 #28282800 #7c6f64
        focused_workspace #28282800 #d65d0eaa #fbf1c7
    }

    tray_padding 2
    font pango:DejaVu Sans Mono 10
    separator_symbol "  "
}

client.focused #3c383633 #d65d0eaa #fbf1c7
client.unfocused #3c383633 #282828aa #a89984
client.focused_inactive #3c383633 #504945aa #a89984

include /etc/sway/config.d/*

for_window [app_id="org.telegram.desktop"] border pixel 2
#assign [class="zoom"] work-view
#assign [class="Skype"] work-view
#assign [app_id="Slack"] work-view
#assign [class="Slack"] work-view
#assign [app_id="teams-for-linux"] work-view
#assign [app_id="com.github.IsmaelMartinez.teams_for_linux"] work-view
#assign [class="outlook-for-linux"] work-view
for_window [app_id="foot"] opacity $opacity

# Temporary disable it while I'm not working - try running pure wayland
#xwayland disable
exec Telegram -startintray
exec ~/.dropbox-dist/dropboxd
exec megasync
exec ~/.local/bin/lyrics-watcher.sh
exec ~/.local/bin/netstats.sh
#exec ~/.local/bin/start-jellyfin-mpv.sh
exec jellyfin-mpv-shim --no-http > /tmp/jms.log
#exec steam

# Use 6500 to disable.
# Batumi: 41.65 41.65.
exec wlsunset -l 41.65 -L 41.65 -t 5000 -T 6000

# Swaylock after boot
exec swaylock

seat seat0 hide_cursor 3000

for_window [app_id="foot_tilda"] mark tilda, move scratchpad, border none
bindsym $mod+F12 [con_mark="tilda"] scratchpad show
exec ~/.local/bin/foot-tilda.sh

for_window [class="io.github.aaddrick.claude-desktop-debian"] mark claude, move scratchpad
bindsym $mod+F11 [con_mark="claude"] scratchpad show
#exec claude-desktop

# Slideshow wallpapers.
exec ~/.local/bin/slideshow.sh

# For NitroType typing.
for_window [app_id="firefox"] mark nitrotype, floating enable, move scratchpad, border none
# 100% zoom - 750 260
exec swaymsg '[con_mark="nitrotype"]' resize set 750 260
bindsym $mod+F10 [con_mark="nitrotype"] scratchpad show

# Pavucontrol
for_window [app_id="org.pulseaudio.pavucontrol"] floating enable
