( if
( contains ( window_class ) "Gvim" )
( begin
( spawn_async (str "transset-df -i " (window_xid) " 0.85" ))
)
)

( if
( contains ( window_class ) "URxvt" )
( begin
( spawn_async (str "transset-df -i " (window_xid) " 0.85" ))
)
)

( if
( contains ( window_class ) "Tilda" )
( begin
( spawn_async (str "transset-df -i " (window_xid) " 0.65" ))
)
)
