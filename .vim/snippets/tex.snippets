snippet euc tkz-euclide graphics
	\begin{figure}[ht]
		\begin{tikzpicture}[thick]
			%Coordinates
			\coordinate (${1:A}) at (${2:0,0});
			\coordinate (${3:A}) at (${4:0,0});
			\coordinate (${5:A}) at (${6:0,0});

			%Names
			\node ($1-label) [${7:above} of $1] {$$1$};
			\node ($3-label) [${8:above} of $3] {$$3$};
			\node ($5-label) [${9:above} of $5] {$$5$};

			%Captions
			\tkzLabelSegment[${10:right}](${11:$1,$3})
			\tkzLabelSegment[${12:right}](${13:$1,$5})

			%Lines
			\draw[${14:line width=0.7mm,}${15:dashed,}${16:->}] (${17:$1})--(${18:$2});
		\end{tikzpicture}
		\caption{${19}}
		\label{fig:${20}}
	\end{figure}
	${0}

snippet f figure with \includegraphics
	\begin{figure}[ht]
		\includegraphics[width=${1:1}\linewidth]{Figures/${2}}
		\caption{${3}}
		\label{fig:${4}}
	\end{figure}
	${0}

snippet fs figure with \subfloat
	\begin{figure}[ht]
		\subfloat[]{\includegraphics[width=${1:.5}\linewidth]{Figures/${2}}}
		\qquad
		\subfloat[]{\includegraphics[width=${3:.5}\linewidth]{Figures/${4}}}
		\caption{${5} (а) ${6}; (б) ${7}}
		\label{fig:${8}}
	\end{figure}
	${0}

snippet verb verbatim block
	\begin{verbatim}
		${1}
	\end{verbatim}
	${0}

snippet se section with * and TOC
	\section*{${1:}}
	\addcontentsline{toc}{section}{$1}
	${0}

snippet fr frame with centered image
	\begin{frame}{${1:}}
		\centering
		\includegraphics[width=${2:.8}\linewidth]{../Figures/${3:}}
	\end{frame}
	${0}

snippet frcol frame with columns
	\begin{frame}{${1:}}
		\begin{columns}
			\column{${2:.4}\textwidth}
			\centering
			\includegraphics[width=${3:1}\linewidth]{../Figures/${4:}}
			\column{${5:.6}\textwidth}
			\begin{itemize}
				\pause\item ${0}
			\end{itemize}
		\end{columns}
	\end{frame}

snippet m minted environment
	\begin{minted}[gobble=${1:4},fontsize=\small]{${2:tex}}
		${0}
	\end{minted}

