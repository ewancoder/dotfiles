{
    "CantoCurses": {
        "browser": {
            "path": " chromium %u"
        },
        "color": {
            "0": 119,
            "1": 227,
            "2": 172,
            "3": 210,
            "4": 141,
            "5": 40
        },
        "reader": {
            "enumerate_links": false,
            "key": {
                "d": "toggle reader.show_description",
                "down": "scroll-down",
                "f": "fetch",
                "g": "goto",
                "j": "scroll-down",
                "k": "scroll-up",
                "l": "toggle reader.enumerate_links",
                "npage": "page-down",
                "ppage": "page-up",
                "space": "destroy",
                "up": "scroll-up"
            }
        },
        "taglist": {
            "border": true,
            "key": {
                "$": "item-state read t:. 0-.",
                "+": "promote",
                "-": "demote",
                "/": "search",
                ";": "toggle-collapse",
                "?": "search-regex",
                "C": "collapse *",
                "C-u": "unset-cursor",
                "E": "toggle taglist.tags_enumerated",
                "J": "next-tag",
                "K": "prev-tag",
                "M": "item-state -marked *",
                "R": "item-state read *",
                "U": "item-state -read *",
                "V": "uncollapse *",
                "b": "yank",
                "c": "toggle-collapse",
                "down": "rel-set-cursor 1",
                "e": "toggle story.enumerated",
                "f10": "transform None",
                "f9": "transform filter_read",
                "g": "foritems & goto & item-state read & clearitems",
                "h": "item-state -read",
                "j": "rel-set-cursor 1",
                "k": "rel-set-cursor -1",
                "l": "item-state read",
                "n": "next-marked",
                "npage": "page-down",
                "p": "prev-marked",
                "ppage": "page-up",
                "q": "update",
                "r": "tag-state read",
                "space": "foritem & item-state read & reader",
                "u": "tag-state -read",
                "up": "rel-set-cursor -1"
            }
        },
        "tagorder": [
            "maintag:Habrahabr",
            "maintag:Onliner",
            "maintag:OpenNet news",
            "maintag:IXBT software news",
            "maintag:IXBT hardware news",
            "maintag:IXBT articles",
            "maintag:Slashdot",
            "maintag:Canto"
        ]
    },
    "defaults": {
        "global_transform": "filter_read",
        "keep_time": 86400,
        "keep_unread": true,
        "rate": 10
    },
    "feeds": [
        {
            "name": "Canto",
            "url": "http://codezen.org/static/canto.xml"
        },
        {
            "name": "Slashdot",
            "url": "http://rss.slashdot.org/slashdot/Slashdot"
        },
        {
            "name": "Habrahabr",
            "url": "http://habrahabr.ru/rss"
        },
        {
            "name": "Onliner",
            "url": "http://onliner.by/feed"
        },
        {
            "name": "IXBT articles",
            "url": "http://www.ixbt.com/export/articles.rss"
        },
        {
            "name": "IXBT hardware news",
            "url": "http://www.ixbt.com/export/hardnews.rss"
        },
        {
            "name": "IXBT software news",
            "url": "http://www.ixbt.com/export/softnews.rss"
        },
        {
            "name": "OpenNet news",
            "url": "http://www.opennet.ru/opennews/opennews_all_noadv.rss"
        }
    ],
    "tags": {
        "maintag:Habrahabr": {
            "collapsed": false
        },
        "maintag:IXBT articles": {
            "collapsed": false
        },
        "maintag:IXBT hardware news": {
            "collapsed": false
        },
        "maintag:IXBT software news": {
            "collapsed": false
        },
        "maintag:Onliner": {
            "collapsed": false
        },
        "maintag:OpenNet news": {
            "collapsed": false
        },
        "maintag:Slashdot": {
            "collapsed": false
        }
    }
}