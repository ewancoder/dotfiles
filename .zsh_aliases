#Exit wmii properly
alias quit='wmiir xwrite /ctl quit'

#=== GIT ===
alias github='ssh-add ~/.ssh/github'
alias gia='git add -A'
alias gic='git commit -v'
alias gic!='git commit -v --amend'
alias gica='git commit -av'
alias gica!='git commit -av --amend'
alias gid='git diff'
alias gil='git log --oneline --graph --color --all --decorate'
alias gim='git merge --no-ff'
alias gip='git push origin --all; if [ ! $? -eq 0 ]; then github; git push origin --all; fi'
alias gipp='git pull; if [ ! $? -eq 0 ]; then github; git pull; fi'
alias gis='git status'

#=== Some utils===
#Lock screen
alias lock='xdotool mousemove - 1 mousemove restore; xscreensaver-command --lock'
#Server sshfs
alias ng='sshfs root@192.168.100.110:/usr/share/nginx/html ~/html'
#For aliases working with sudo
alias s='sudo '
#Reattach screen session(s)
alias sc='screen -rd'
#Screenshot of a window
alias scr='xdotool mousemove - 1 mousemove restore; scrot -s `date +%d%H%M%S`.png'
#Connect to RPI over ssh
alias sshrpi='ssh -t root@192.168.100.110'
#SSH background tunnel
alias sshl='ssh -fNL 7070:127.0.0.1:7070 root@192.168.100.110'
#Typo fix
alias xit='exit'

#=== Software ===
#Anylogic
alias al='/mnt/cloud/Copy/Portable\ Software/anylogic/anylogic'
#Canto-curses client
alias canto='canto-curses -a 127.0.0.1 -p 7070 -v'
#Gparted
alias gpart='xdotool mousemove - 1 mousemove restore; gksu gparted'
#Minecraft FeedTheBeast
alias ftb='java -jar ~/Copy/Games/Minecraft/Feed\ The\ Beast/ftb.jar'
#Impressive
alias imp='impressive --darkness 60 -ff'
#Popcorn-Time
alias pt='~/Copy/Popcorn-Time/Popcorn-Time'
#Terraria TShock Server
alias terr='cd ~/Copy/GameSaves/Terraria && mono TerrariaServer.exe'
#Warsow (on the second workspace)
alias war='warsow & sleep 5 && wmiir xwrite /ctl view 2'
