#=== Messages code ===
mess() {
    # Styles.
    Bold="\033[1m"
    Def="\033[0m"
    Red="\033[91m"
    Green="\033[92m"

    # Determine 'option' and 'message'.
    if [ "${#1}" -gt "2" ]; then
        o=$2
        m=$1
    else
        o=$1
        m=$2
    fi

    # Stylize message.
    case $o in
        "-w")
            Style="\n$Bold$Red! $m$Def"
            ;;
        "-t")
            Line="----------"
            Style="\n$Line\n$Bold$Green [ $m ]$Def\n$Line"
            ;;
        *)
            Style="$Bold$Green\n-> $Def$Bold$m$Def"
            ;;
    esac

    # Print message.
    echo -e "$Style"
}

